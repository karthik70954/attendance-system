# Database - Get from neon.tech
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"

# JWT Secret - Use a long random string
JWT_SECRET="your-super-secret-jwt-key-change-this-to-something-long-and-random"

# Setup key - Used to create the first manager account
SETUP_KEY="your-setup-key-123"

# Email notifications (Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# Manager email (for missed check-in alerts)
MANAGER_EMAIL="manager@yourstore.com"
