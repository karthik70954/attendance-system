// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Manager {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Employee {
  id               String            @id @default(cuid())
  name             String
  shortName        String
  email            String?           @unique
  phone            String?
  dailyRate        Float             @default(0)
  drivingRate      Float             @default(0)
  faceData         String?           // base64 face descriptor JSON
  photoUrl         String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  attendance       Attendance[]
  schedules        Schedule[]
  monthlySchedules MonthlySchedule[]
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  date       DateTime  @default(now())
  checkInAt  DateTime  @default(now())
  shiftType  ShiftType @default(INSTORE)
  dayType    DayType   @default(FULL)
  notes      String?
  createdAt  DateTime  @default(now())

  @@unique([employeeId, date])
}

model Schedule {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  dayOfWeek  Int      // 0=Sun, 1=Mon ... 6=Sat
  startTime  String   // "09:00"
  active     Boolean  @default(true)
}

enum ShiftType {
  INSTORE
  INSTORE_DRIVING
}

enum DayType {
  FULL
  HALF
}

model MonthlySchedule {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  year       Int       // e.g. 2026
  month      Int       // 1-12
  date       DateTime  // the actual date
  shiftType  ShiftType @default(INSTORE)
  dayType    DayType   @default(FULL)
  startTime  String    @default("09:00")
  notes      String?
  alertSent  Boolean   @default(false) // true once missed-checkin alert sent
  createdAt  DateTime  @default(now())

  @@unique([employeeId, date])
  @@index([year, month])
}
